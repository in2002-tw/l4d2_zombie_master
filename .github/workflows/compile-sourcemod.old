name: Compile SourceMod Plugins

on:
  push:
    branches:
      - main
  pull_request:
    branches:
      - main

permissions:
  contents: write

jobs:
  compile:
    runs-on: ubuntu-latest

    env:
      scripting_dir: left4dead2/addons/sourcemod/scripting

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up SourcePawn compiler (SourceMod latest stable 1.12)
        uses: rumblefrog/setup-sp@master
        with:
          version: 1.12.x

      - name: Download required third-party includes
        shell: bash
        run: |
          set -euo pipefail

          include_dir="$GITHUB_WORKSPACE/.ci/includes"
          mkdir -p "$include_dir"

          download_with_fallback() {
            local output_file="$1"
            shift

            local url
            for url in "$@"; do
              if curl --fail --silent --show-error --location \
                --retry 6 --retry-delay 2 --retry-all-errors \
                "$url" -o "$output_file"; then
                return 0
              fi

              echo "Download failed from: $url" >&2
            done

            echo "Unable to download required file: $output_file" >&2
            return 1
          }

          for include_file in \
            left4dhooks.inc \
            left4dhooks_anim.inc \
            left4dhooks_silver.inc \
            left4dhooks_lux_library.inc \
            left4dhooks_stocks.inc
          do
            download_with_fallback \
              "$include_dir/$include_file" \
              "https://raw.githubusercontent.com/SilvDev/Left4DHooks/main/sourcemod/scripting/include/$include_file" \
              "https://cdn.jsdelivr.net/gh/SilvDev/Left4DHooks@main/sourcemod/scripting/include/$include_file"
          done

          if [ -z "${includePath:-}" ] || [ ! -f "${includePath}/dhooks.inc" ]; then
            download_with_fallback \
              "$include_dir/dhooks.inc" \
              "https://raw.githubusercontent.com/alliedmodders/sourcemod/master/plugins/include/dhooks.inc" \
              "https://cdn.jsdelivr.net/gh/alliedmodders/sourcemod@master/plugins/include/dhooks.inc"
          fi

      - name: Compile every plugin
        shell: bash
        run: |
          set -euo pipefail
          shopt -s nullglob

          build_dir="$GITHUB_WORKSPACE/build"
          mkdir -p "$build_dir"

          sources=("$GITHUB_WORKSPACE/$scripting_dir"/*.sp)
          if [ ${#sources[@]} -eq 0 ]; then
            echo "No .sp source files found under $scripting_dir" >&2
            exit 1
          fi

          for src in "${sources[@]}"; do
            name="$(basename "${src%.sp}")"
            echo "::group::Compiling $name"
            spcomp \
              -v2 \
              -E \
              -i"$GITHUB_WORKSPACE/$scripting_dir/include" \
              -i"$GITHUB_WORKSPACE/.ci/includes" \
              "$src" \
              -o"$build_dir/$name.smx"
            echo "::endgroup::"
          done

      - name: Upload compiled plugin artifacts
        uses: actions/upload-artifact@v4
        with:
          name: compiled-plugins-sourcemod-1.12
          path: build/*.smx
          if-no-files-found: error

      - name: Publish a release for each bumped plugin
        if: github.event_name == 'push' && github.ref == 'refs/heads/main'
        shell: bash
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          set -euo pipefail
          shopt -s nullglob

          for src in "$GITHUB_WORKSPACE/$scripting_dir"/*.sp; do
            name="$(basename "${src%.sp}")"

            # Pull the first whitespace-delimited token from the PLUGIN_VERSION
            # string, dropping any trailing date (e.g. "0.9.2 2026-06-19" -> "0.9.2").
            version="$(sed -nE 's/.*#define[[:space:]]+PLUGIN_VERSION[[:space:]]+"([^" ]+).*/\1/p' "$src" | head -n1)"
            if [ -z "$version" ]; then
              echo "No PLUGIN_VERSION in $name, skipping release."
              continue
            fi

            tag="${name}-${version}"

            if gh release view "$tag" >/dev/null 2>&1; then
              echo "Release $tag already exists, nothing to publish."
              continue
            fi

            echo "Publishing release $tag"
            gh release create "$tag" \
              "build/$name.smx" \
              --target "$GITHUB_SHA" \
              --title "$name $version" \
              --notes "Automated release of $name version $version."
          done
