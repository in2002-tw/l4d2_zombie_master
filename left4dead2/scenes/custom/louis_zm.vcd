// Choreo version 1
event stoppoint "FireCompletion"
  time 3.011000 -1.000000
  param ""
actor "Manager"
  channel "audio"
    event speak "SpeakEvent"
    {
      time 0.000000 3.011000
      param "CustomVoice_Louis_ZM"
      fixedlength
      cctype "cc_master"
      cctoken ""
    }
  channel "look at"
  channel "move to"
  channel "gestures"
  channel "postures"
  channel "facial flex"
  channel "triggers"
scalesettings
  "CChoreoView" "384"
  "ExpressionTool" "100"
  "RampTool" "66"
  "GestureTool" "100"
  "SceneRampTool" "100"
fps 60
snap off
ignorePhonemes off
